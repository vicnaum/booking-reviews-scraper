{
  "name": "stayreviewr-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "dotenv -e .env.local -- tsx src/lib/search-worker.ts",
    "worker:dev": "dotenv -e .env.local -- tsx watch src/lib/search-worker.ts",
    "lint": "next lint",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "@turf/turf": "^7.3.4",
    "axios": "^1.13.6",
    "bullmq": "^5.71.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.10.0",
    "leaflet": "^1.9.4",
    "next": "^15.1.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.0",
    "prisma": "^6.2.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
