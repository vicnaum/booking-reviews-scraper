generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  airbnb
  booking
}

enum JobStatus {
  pending
  running
  completed
  failed
  cancelled
}

enum PhaseStatus {
  pending
  running
  completed
  failed
  skipped
  partial
}

enum SearchAreaMode {
  window
  rectangle
  circle
}

model SearchJob {
  id           String    @id @default(cuid())
  status       JobStatus @default(pending)
  platform     Platform
  location     String?
  boundingBox  Json?
  checkin      String?
  checkout     String?
  adults       Int       @default(2)
  currency     String    @default("USD")
  filters      Json?
  totalResults Int       @default(0)
  pagesScanned Int       @default(0)
  progress     Float     @default(0)
  errorMessage String?
  bullJobId    String?
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?
  results      SearchResult[]
}

model SearchResult {
  id               String   @id @default(cuid())
  jobId            String
  job              SearchJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  listingId        String
  platform         Platform
  name             String
  url              String
  rating           Float?
  reviewCount      Int      @default(0)
  priceAmount      Float?
  priceCurrency    String?
  totalPrice       Float?
  pricing          Json?
  lat              Float?
  lng              Float?
  propertyType     String?
  photoUrl         String?
  bedrooms         Int?
  beds             Int?
  bathrooms        Int?
  maxGuests        Int?
  superhost        Boolean?
  instantBook      Boolean?
  hostId           String?
  stars            Int?
  freeCancellation Boolean?
  createdAt        DateTime @default(now())

  @@unique([jobId, listingId, platform])
  @@index([jobId])
}

model ReviewJob {
  id             String          @id @default(cuid())
  ownerKey       String?
  isPublic       Boolean         @default(false)
  status         JobStatus       @default(pending)
  currentPhase   String          @default("search")
  analysisStatus PhaseStatus     @default(pending)
  analysisCurrentPhase String?
  location       String?
  prompt         String?
  boundingBox    Json?
  circle         Json?
  poi            Json?
  mapBounds      Json?
  mapCenter      Json?
  mapZoom        Int?
  searchAreaMode SearchAreaMode  @default(window)
  checkin        String?
  checkout       String?
  adults         Int             @default(2)
  currency       String          @default("USD")
  filters        Json?
  totalResults   Int             @default(0)
  pagesScanned   Int             @default(0)
  progress       Float           @default(0)
  errorMessage   String?
  queueJobId     String?
  analysisQueueJobId String?
  artifactRoot   String?
  reportPath     String?
  createdAt      DateTime        @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  durationMs     Int?
  analysisProgress Float         @default(0)
  analysisErrorMessage String?
  analysisStartedAt DateTime?
  analysisCompletedAt DateTime?
  analysisDurationMs Int?
  listings       ReviewJobListing[]
  events         ReviewJobEvent[]

  @@index([ownerKey, createdAt])
}

model ReviewJobListing {
  id               String    @id @default(cuid())
  jobId            String
  job              ReviewJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  listingId        String
  platform         Platform
  name             String
  url              String
  rating           Float?
  reviewCount      Int       @default(0)
  priceAmount      Float?
  priceCurrency    String?
  totalPrice       Float?
  pricing          Json?
  lat              Float?
  lng              Float?
  propertyType     String?
  photoUrl         String?
  bedrooms         Int?
  beds             Int?
  bathrooms        Int?
  maxGuests        Int?
  superhost        Boolean?
  instantBook      Boolean?
  hostId           String?
  stars            Int?
  freeCancellation Boolean?
  selected         Boolean   @default(false)
  liked            Boolean   @default(false)
  hidden           Boolean   @default(false)
  poiDistanceMeters Float?
  createdAt        DateTime  @default(now())
  analysis         ReviewJobListingAnalysis?

  @@unique([jobId, listingId, platform])
  @@index([jobId, createdAt])
}

model ReviewJobListingAnalysis {
  id              String    @id @default(cuid())
  jobListingId    String    @unique
  jobListing      ReviewJobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  status          PhaseStatus @default(pending)
  currentPhase    String      @default("pending")
  errorMessage    String?
  detailsStatus   PhaseStatus @default(pending)
  reviewsStatus   PhaseStatus @default(pending)
  photosStatus    PhaseStatus @default(pending)
  aiReviewsStatus PhaseStatus @default(pending)
  aiPhotosStatus  PhaseStatus @default(pending)
  triageStatus    PhaseStatus @default(pending)
  details         Json?
  aiReviews       Json?
  aiPhotos        Json?
  triage          Json?
  reviewCount     Int?
  photoCount      Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?

  @@index([status, updatedAt])
}

model ReviewJobEvent {
  id             String    @id @default(cuid())
  jobId          String
  job            ReviewJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  phase          String
  level          String
  message        String
  payload        Json?
  listingId      String?
  listingPlatform Platform?
  createdAt      DateTime  @default(now())

  @@index([jobId, createdAt])
}
